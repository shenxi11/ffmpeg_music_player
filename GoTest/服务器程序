// getMusicHandler retrieves detailed metadata for a specific music file.
// Accepts 'path' parameter (the relative path from /files response)
// Returns all resource URLs for the music file
func getMusicHandler(w http.ResponseWriter, r *http.Request) {
	enableCORS(w)
	musicPath := r.URL.Query().Get("path")
	if musicPath == "" {
		http.Error(w, "path parameter is required", http.StatusBadRequest)
		return
	}

	cacheKey := CACHE_PREFIX_MUSIC + "details:" + musicPath
	if cachedResult, err := rdb.Get(ctx, cacheKey).Result(); err == nil {
		w.Header().Set("Content-Type", "application/json")
		w.Write([]byte(cachedResult))
		return
	}

	var musicFile MusicFile
	var lrcPath, coverArtPath sql.NullString
	err := db.QueryRowContext(r.Context(),
		"SELECT id, path, title, artist, album, duration_sec, lrc_path, cover_art_path FROM music_files WHERE path = ?",
		musicPath,
	).Scan(
		&musicFile.ID, &musicFile.Path, &musicFile.Title, &musicFile.Artist, &musicFile.Album, &musicFile.DurationSec, &lrcPath, &coverArtPath,
	)

	if err != nil {
		if err == sql.ErrNoRows {
			http.Error(w, "Music not found", http.StatusNotFound)
		} else {
			log.Printf("Error getting music details for '%s': %v", musicPath, err)
			http.Error(w, "Internal server error", http.StatusInternalServerError)
		}
		return
	}

	// Build the response with full URLs
	baseURL := getBaseURL(r)
	response := MusicResponse{
		StreamURL: fmt.Sprintf("%s/stream/%s", baseURL, musicFile.Path),
		Duration:  &musicFile.DurationSec,
		Title:     musicFile.Title,
		Artist:    musicFile.Artist,
		Album:     musicFile.Album,
	}

	// Add LRC URL if exists
	if lrcPath.Valid && lrcPath.String != "" {
		lrcURL := fmt.Sprintf("%s/lrc?path=%s", baseURL, lrcPath.String)
		response.LrcURL = &lrcURL
	}

	// Add album cover URL if exists
	if coverArtPath.Valid && coverArtPath.String != "" {
		coverURL := fmt.Sprintf("%s/files/%s", baseURL, coverArtPath.String)
		response.AlbumCoverURL = &coverURL
	}

	responseJSON, err := json.Marshal(response)
	if err != nil {
		log.Printf("Error marshalling music details to JSON: %v", err)
		http.Error(w, "Could not generate music details response", http.StatusInternalServerError)
		return
	}

	rdb.Set(ctx, cacheKey, responseJSON, CACHE_TTL_LONG)

	w.Header().Set("Content-Type", "application/json")
	w.Write(responseJSON)
}

// Legacy handlers for compatibility
func getRecordsHandler(w http.ResponseWriter, r *http.Request) {
	enableCORS(w)

	rows, err := db.QueryContext(r.Context(), "SELECT id, name, value FROM records")
	if err != nil {
		http.Error(w, "Failed to query records: "+err.Error(), http.StatusInternalServerError)
		return
	}
	defer rows.Close()

	type Record struct {
		ID    int    `json:"id"`
		Name  string `json:"name"`
		Value string `json:"value"`
	}

	var records []Record
	for rows.Next() {
		var rec Record
		if err := rows.Scan(&rec.ID, &rec.Name, &rec.Value); err != nil {
			http.Error(w, "Failed to scan record: "+err.Error(), http.StatusInternalServerError)
			return
		}
		records = append(records, rec)
	}

	w.Header().Set("Content-Type", "application/json")
	json.NewEncoder(w).Encode(records)
}

func addRecordHandler(w http.ResponseWriter, r *http.Request) {
	enableCORS(w)
	if r.Method != "POST" {
		http.Error(w, "Only POST method is allowed", http.StatusMethodNotAllowed)
		return
	}

	var record struct {
		Name  string `json:"name"`
		Value string `json:"value"`
	}
	err := json.NewDecoder(r.Body).Decode(&record)
	if err != nil {
		http.Error(w, "Invalid request body", http.StatusBadRequest)
		return
	}

	_, err = db.ExecContext(r.Context(), "INSERT INTO records (name, value) VALUES (?, ?)", record.Name, record.Value)
	if err != nil {
		http.Error(w, "Failed to add record: "+err.Error(), http.StatusInternalServerError)
		return
	}

	w.WriteHeader(http.StatusCreated)
	fmt.Fprintln(w, "Record added successfully")
}

func main() {
	// 设置日志输出到文件和控制台
	logFile, err := os.OpenFile("server.log", os.O_CREATE|os.O_WRONLY|os.O_APPEND, 0666)
	if err != nil {
		log.Fatalf("Failed to open log file: %v", err)
	}
	mw := io.MultiWriter(os.Stdout, logFile)
	log.SetOutput(mw)

	// 加载配置
	configFile, err := os.ReadFile("config.yaml")
	if err != nil {
		log.Fatalf("Cannot read config file: %v", err)
	}
	err = yaml.Unmarshal(configFile, &config)
	if err != nil {
		log.Fatalf("Cannot parse config file: %v", err)
	}

	UPLOAD_FOLDER = config.Server.UploadDir
	STATIC_FOLDER = config.Server.StaticDir

	// 初始化数据库和Redis
	initDB()
	defer db.Close()
	initRedis()
	defer rdb.Close()

	// 确保上传目录存在
	os.MkdirAll(UPLOAD_FOLDER, os.ModePerm)

	// 创建一个新的 ServeMux 并注册所有路由
	mux := http.NewServeMux()
	mux.HandleFunc("/users/register", registerHandler)
	mux.HandleFunc("/users/login", loginHandler)
	mux.HandleFunc("/users/add_music", addMusicHandler)
	mux.HandleFunc("/get_records", getRecordsHandler)
	mux.HandleFunc("/add_record", addRecordHandler)

	// Music API handlers
	mux.HandleFunc("/files", filesHandler)
	mux.HandleFunc("/stream", streamHandler)           // POST request for streaming
	mux.HandleFunc("/uploads/", serveAudioFileHandler) // Serve audio/lrc/cover files
	mux.HandleFunc("/lrc", lrcHandler)
	mux.HandleFunc("/files/", downloadHandler) // Handles /files/<filename>
	mux.HandleFunc("/ack", ackHandler)
	mux.HandleFunc("/get_music", getMusicHandler)

	// 文件上传
	mux.HandleFunc("/upload", func(w http.ResponseWriter, r *http.Request) {
		enableCORS(w)
		if r.Method == "OPTIONS" {
			w.WriteHeader(http.StatusOK)
			return
		}
		if r.Method != "POST" {
			http.Error(w, "Only POST method is allowed", http.StatusMethodNotAllowed)
			return
		}

		file, handler, err := r.FormFile("file")
		if err != nil {
			http.Error(w, "Failed to get file from form", http.StatusBadRequest)
			return
		}
		defer file.Close()

		filePath := filepath.Join(UPLOAD_FOLDER, handler.Filename)
		dst, err := os.Create(filePath)
		if err != nil {
			http.Error(w, "Failed to create file on server", http.StatusInternalServerError)
			return
		}
		defer dst.Close()

		if _, err := io.Copy(dst, file); err != nil {
			http.Error(w, "Failed to save file", http.StatusInternalServerError)
			return
		}

		w.Header().Set("Content-Type", "application/json")
		json.NewEncoder(w).Encode(map[string]string{"filePath": filePath})
	})

	// 静态文件服务
	fs := http.FileServer(http.Dir(STATIC_FOLDER))
	mux.Handle("/static/", http.StripPrefix("/static/", fs))

	// 健康检查和状态
	mux.HandleFunc("/health", func(w http.ResponseWriter, r *http.Request) {
		enableCORS(w)

		// Check DB and Redis connection
		dbErr := db.Ping()
		_, redisErr := rdb.Ping(ctx).Result()

		status := map[string]interface{}{
			"status":    "ok",
			"timestamp": time.Now().Unix(),
			"database":  dbErr == nil,
			"redis":     redisErr == nil,
		}

		w.Header().Set("Content-Type", "application/json")
		json.NewEncoder(w).Encode(status)
	})

	// Redis 统计信息
	mux.HandleFunc("/stats", func(w http.ResponseWriter, r *http.Request) {
		enableCORS(w)
		info, err := rdb.Info(ctx, "stats").Result()
		if err != nil {
			http.Error(w, "Could not get Redis stats", http.StatusInternalServerError)
			return
		}
		w.Header().Set("Content-Type", "text/plain")
		w.Write([]byte(info))
	})

	// 启动服务器
	addr := fmt.Sprintf("%s:%d", config.Server.Host, config.Server.Port)
	server := &http.Server{
		Addr:         addr,
		Handler:      loggingHandler(mux), // 应用日志中间件
		ReadTimeout:  0,                   // 不限制读取超时（适合大文件/慢客户端）
		WriteTimeout: 0,                   // 不限制写入超时，防止长流被截断
		IdleTimeout:  10 * time.Minute,    // 允许空闲长连接
	}

	fmt.Println("Server is starting...")
	fmt.Printf("Listening on http://%s\n", addr)
	fmt.Println("Available routes:")
	fmt.Println("  POST /users/register           - Register a new user")
	fmt.Println("  POST /users/login              - Login a user")
	fmt.Println("  POST /users/add_music          - Add a music path for a user")
	fmt.Println("  GET  /files                    - Get all music files (returns array with path, duration, cover_art_url)")
	fmt.Println("  POST /stream                   - Get music metadata and URLs (POST {\"filename\": \"xxx.mp3\"})")
	fmt.Println("  GET  /uploads/<path>           - Serve audio/image files")
	fmt.Println("  GET  /uploads/<folder>/lrc     - Get lyric file as JSON array")
	fmt.Println("  GET  /get_music?path=<path>    - Get music metadata and resource URLs")
	fmt.Println("  GET  /lrc?path=<path>          - Get a lyric file (returns JSON array)")
	fmt.Println("  GET  /files/<path>             - Download a file")
	fmt.Println("  POST /upload                   - Upload a file")
	fmt.Println("  GET  /static/<filename>        - Serve static files")
	fmt.Println("  GET  /health                   - Health check")
	fmt.Println("  GET  /stats                    - Redis statistics")
	fmt.Printf("Database: %s\n", "Connected")
	fmt.Printf("Redis: %s\n", "Connected")

	log.Fatal(server.ListenAndServe())
}
