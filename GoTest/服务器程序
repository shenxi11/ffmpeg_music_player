// Cache constants
const (
	CACHE_PREFIX_USER  = "user:"
	CACHE_PREFIX_MUSIC = "music:"
	CACHE_PREFIX_STATS = "stats:"
	CACHE_TTL_SHORT    = 5 * time.Minute  // 短期缓存
	CACHE_TTL_MEDIUM   = 30 * time.Minute // 中期缓存
	CACHE_TTL_LONG     = 2 * time.Hour    // 长期缓存
)

// Utility functions

func initDB() {
	dsn := fmt.Sprintf("%s:%s@tcp(%s:%d)/%s?charset=utf8mb4&parseTime=True&loc=Local",
		config.Database.User,
		config.Database.Password,
		config.Database.Host,
		config.Database.Port,
		config.Database.Name,
	)

	var err error
	db, err = sql.Open("mysql", dsn)
	if err != nil {
		log.Fatalf("Cannot create database connection: %v", err)
	}

	// Set connection pool settings
	db.SetConnMaxLifetime(time.Minute * 3)
	db.SetMaxOpenConns(10)
	db.SetMaxIdleConns(10)

	// Test connection
	err = db.Ping()
	if err != nil {
		log.Printf("Database connection failed: %v", err)
	} else {
		log.Println("Database connected successfully")
	}
}

func initRedis() {
	addr := fmt.Sprintf("%s:%d", config.Redis.Host, config.Redis.Port)
	rdb = redis.NewClient(&redis.Options{
		Addr:     addr,
		Password: "", // no password set
		DB:       0,  // use default DB
	})

	_, err := rdb.Ping(ctx).Result()
	if err != nil {
		log.Printf("Redis connection failed: %v", err)
	} else {
		log.Println("Redis connected successfully")
	}
}

func enableCORS(w http.ResponseWriter) {
	w.Header().Set("Access-Control-Allow-Origin", "*")
	w.Header().Set("Access-Control-Allow-Methods", "POST, GET, OPTIONS, PUT, DELETE")
	w.Header().Set("Access-Control-Allow-Headers", "Accept, Content-Type, Content-Length, Accept-Encoding, X-CSRF-Token, Authorization")
}

// getBaseURL returns the base URL for the server
// It uses the X-Forwarded-Host header if available (for proxied requests),
// then the public_host from config, and falls back to getting the actual IP
func getBaseURL(r *http.Request) string {
	// 直接返回硬编码的域名和端口
	return "http://slcdut.xyz:8080"
} // getOutboundIP gets the preferred outbound IP of this machine
func getOutboundIP() string {
	conn, err := net.Dial("udp", "8.8.8.8:80")
	if err != nil {
		return ""
	}
	defer conn.Close()

	localAddr := conn.LocalAddr().(*net.UDPAddr)
	return localAddr.IP.String()
}

// loggingResponseWriter is a wrapper around http.ResponseWriter that allows us to capture the status code.
type loggingResponseWriter struct {
	http.ResponseWriter
	statusCode int
}

func newLoggingResponseWriter(w http.ResponseWriter) *loggingResponseWriter {
	// Default to 200 OK if WriteHeader is not called.
	return &loggingResponseWriter{w, http.StatusOK}
}

func (lrw *loggingResponseWriter) WriteHeader(code int) {
	lrw.statusCode = code
	lrw.ResponseWriter.WriteHeader(code)
}

// loggingHandler is a middleware that logs the details of each request.
func loggingHandler(next http.Handler) http.Handler {
	return http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {
		start := time.Now()
		lrw := newLoggingResponseWriter(w)

		// Call the next handler in the chain.
		next.ServeHTTP(lrw, r)

		duration := time.Since(start)
		log.Printf(
			"Request: %s %s | Status: %d | Duration: %s | From: %s",
			r.Method,
			r.RequestURI,
			lrw.statusCode,
			duration,
			r.RemoteAddr,
		)
	})
}

// Handlers

func registerHandler(w http.ResponseWriter, r *http.Request) {
	enableCORS(w)
	if r.Method == "OPTIONS" {
		w.WriteHeader(http.StatusOK)
		return
	}

	var req RegisterRequest
	if err := json.NewDecoder(r.Body).Decode(&req); err != nil {
		http.Error(w, "Missing or invalid fields", http.StatusBadRequest)
		return
	}

	// Basic validation
	if req.Account == "" || req.Password == "" || req.Username == "" {
		http.Error(w, "Account, password, and username are required", http.StatusBadRequest)
		return
	}

	// In a real application, you should hash the password.
	// For this example, we'll store it as plain text to match the C++ logic.
	_, err := db.ExecContext(r.Context(), "INSERT INTO users (account, password, username) VALUES (?, ?, ?)", req.Account, req.Password, req.Username)
	if err != nil {
		// Check for duplicate entry
		if strings.Contains(err.Error(), "Duplicate entry") {
			http.Error(w, "User with this account already exists", http.StatusConflict)
		} else {
			http.Error(w, "Failed to register user: "+err.Error(), http.StatusInternalServerError)
		}
		return
	}

	w.Header().Set("Content-Type", "application/json")
	json.NewEncoder(w).Encode(map[string]bool{"success": true})
}

func loginHandler(w http.ResponseWriter, r *http.Request) {
	enableCORS(w)
	if r.Method == "OPTIONS" {
		w.WriteHeader(http.StatusOK)
		return
	}

	var req LoginRequest
	if err := json.NewDecoder(r.Body).Decode(&req); err != nil {
		http.Error(w, "Missing or invalid fields", http.StatusBadRequest)
		return
	}

	// Check cache first
	cacheKey := CACHE_PREFIX_USER + "login:" + req.Account + ":" + req.Password
	if cachedResult, err := rdb.Get(ctx, cacheKey).Result(); err == nil {
		w.Header().Set("Content-Type", "application/json")
		w.Write([]byte(cachedResult))
		return
	}

	var username string
	var userID int
	err := db.QueryRowContext(r.Context(), "SELECT id, username FROM users WHERE account = ? AND password = ?", req.Account, req.Password).Scan(&userID, &username)

	response := LoginResponse{
		Success:      "false",
		SuccessBool:  false,
		Username:     "",
		SongPathList: []string{},
	}

	if err == nil { // User found
		response.Success = "true"
		response.SuccessBool = true
		response.Username = username
		rows, err := db.QueryContext(r.Context(), "SELECT music_path FROM user_music WHERE user_id = ?", userID)
		if err == nil {
			defer rows.Close()
			for rows.Next() {
				var path string
				if err := rows.Scan(&path); err == nil {
					response.SongPathList = append(response.SongPathList, path)
				}
			}
		}
	} else if err != nil && err != sql.ErrNoRows {
		log.Printf("Database error during login for account %s: %v", req.Account, err)
	}

	resultJSON, _ := json.Marshal(response)

	// Cache successful login for short period
	if response.Success == "true" {
		rdb.Set(ctx, cacheKey, resultJSON, CACHE_TTL_SHORT)
	}

	w.Header().Set("Content-Type", "application/json")
	w.Write(resultJSON)
}

func addMusicHandler(w http.ResponseWriter, r *http.Request) {
	enableCORS(w)
	if r.Method == "OPTIONS" {
		w.WriteHeader(http.StatusOK)
		return
	}

	var req AddMusicRequest
	if err := json.NewDecoder(r.Body).Decode(&req); err != nil {
		http.Error(w, "Missing or invalid fields", http.StatusBadRequest)
		return
	}

	var userID int
	err := db.QueryRowContext(r.Context(), "SELECT id FROM users WHERE username = ?", req.Username).Scan(&userID)
	if err != nil {
		if err == sql.ErrNoRows {
			http.Error(w, "User not found", http.StatusNotFound)
		} else {
			http.Error(w, "Error finding user: "+err.Error(), http.StatusInternalServerError)
		}
		return
	}

	_, err = db.ExecContext(r.Context(), "INSERT INTO user_music (user_id, music_path) VALUES (?, ?)", userID, req.MusicPath)
	if err != nil {
		http.Error(w, "Failed to add music: "+err.Error(), http.StatusInternalServerError)
		return
	}

	w.Header().Set("Content-Type", "application/json")
	json.NewEncoder(w).Encode(map[string]bool{"success": true})
}

