// FileListItem represents a music file in the list response
type FileListItem struct {
	Path        string  `json:"path"`
	Duration    string  `json:"duration"`
	CoverArtURL *string `json:"cover_art_url,omitempty"`
}

// filesHandler retrieves a list of all music files from the database.
// Returns an array of objects with path, duration, and cover art URL
func filesHandler(w http.ResponseWriter, r *http.Request) {
	enableCORS(w)
	if r.Method == "OPTIONS" {
		w.WriteHeader(http.StatusOK)
		return
	}

	// Try to get from cache first
	cacheKey := CACHE_PREFIX_MUSIC + "all_files"
	if cachedResult, err := rdb.Get(ctx, cacheKey).Result(); err == nil {
		w.Header().Set("Content-Type", "application/json")
		w.Write([]byte(cachedResult))
		return
	}

	rows, err := db.QueryContext(r.Context(), "SELECT path, duration_sec, cover_art_path FROM music_files WHERE is_audio = 1")
	if err != nil {
		log.Printf("Error querying music files: %v", err)
		http.Error(w, "Could not retrieve file list", http.StatusInternalServerError)
		return
	}
	defer rows.Close()

	// Build a list of file items with cover art
	var fileList []FileListItem
	baseURL := getBaseURL(r)

	for rows.Next() {
		var path string
		var duration float64
		var coverArtPath sql.NullString

		if err := rows.Scan(&path, &duration, &coverArtPath); err != nil {
			log.Printf("Error scanning music file row: %v", err)
			continue
		}

		item := FileListItem{
			Path:     path,
			Duration: fmt.Sprintf("%.2f seconds", duration),
		}

		// Add cover art URL if exists
		if coverArtPath.Valid && coverArtPath.String != "" {
			coverURL := fmt.Sprintf("%s/uploads/%s", baseURL, coverArtPath.String)
			item.CoverArtURL = &coverURL
		}

		fileList = append(fileList, item)
	}

	if err := rows.Err(); err != nil {
		log.Printf("Error after iterating through music file rows: %v", err)
		http.Error(w, "Error processing file list", http.StatusInternalServerError)
		return
	}

	responseJSON, err := json.Marshal(fileList)
	if err != nil {
		log.Printf("Error marshalling files list to JSON: %v", err)
		http.Error(w, "Could not generate file list response", http.StatusInternalServerError)
		return
	}

	// Cache the result
	rdb.Set(ctx, cacheKey, responseJSON, CACHE_TTL_MEDIUM)

	w.Header().Set("Content-Type", "application/json")
	w.Write(responseJSON)
}

// StreamRequest represents the request to stream a music file
type StreamRequest struct {
	Filename string `json:"filename"`
}

// streamHandler handles POST requests to get music metadata and resource URLs
// This is similar to getMusicHandler but uses filename instead of path for backwards compatibility
func streamHandler(w http.ResponseWriter, r *http.Request) {
	enableCORS(w)

	if r.Method == "OPTIONS" {
		w.WriteHeader(http.StatusOK)
		return
	}

	if r.Method != http.MethodPost {
		http.Error(w, "Method not allowed", http.StatusMethodNotAllowed)
		return
	}

	var req StreamRequest
	if err := json.NewDecoder(r.Body).Decode(&req); err != nil {
		w.Header().Set("Content-Type", "application/json")
		w.WriteHeader(http.StatusBadRequest)
		json.NewEncoder(w).Encode(map[string]string{"error": "Missing filename"})
		return
	}

	filename := strings.TrimSpace(req.Filename)
	if filename == "" {
		w.Header().Set("Content-Type", "application/json")
		w.WriteHeader(http.StatusBadRequest)
		json.NewEncoder(w).Encode(map[string]string{"error": "Filename is required"})
		return
	}

	// Query database for the music file by filename
	var musicFile MusicFile
	var lrcPath, coverArtPath sql.NullString
	err := db.QueryRowContext(r.Context(),
		"SELECT id, path, title, artist, album, duration_sec, lrc_path, cover_art_path FROM music_files WHERE path LIKE ?",
		"%"+filename,
	).Scan(
		&musicFile.ID, &musicFile.Path, &musicFile.Title, &musicFile.Artist, &musicFile.Album, &musicFile.DurationSec, &lrcPath, &coverArtPath,
	)

	if err != nil {
		if err == sql.ErrNoRows {
			w.Header().Set("Content-Type", "application/json")
			w.WriteHeader(http.StatusNotFound)
			json.NewEncoder(w).Encode(map[string]string{"error": "Music file not found"})
		} else {
			log.Printf("Error finding music file '%s': %v", filename, err)
			w.Header().Set("Content-Type", "application/json")
			w.WriteHeader(http.StatusInternalServerError)
			json.NewEncoder(w).Encode(map[string]string{"error": "Internal server error"})
		}
		return
	}

	// Build the response with full URLs
	baseURL := getBaseURL(r)
	response := MusicResponse{
		StreamURL: fmt.Sprintf("%s/uploads/%s", baseURL, musicFile.Path),
		Duration:  &musicFile.DurationSec,
		Title:     musicFile.Title,
		Artist:    musicFile.Artist,
		Album:     musicFile.Album,
	}

	// Add LRC URL if exists
	if lrcPath.Valid && lrcPath.String != "" {
		// Extract folder name from lrc path (e.g., "半兽人/半兽人.lrc" -> "半兽人")
		folderName := filepath.Dir(lrcPath.String)
		lrcURL := fmt.Sprintf("%s/uploads/%s/lrc", baseURL, folderName)
		response.LrcURL = &lrcURL
	}

	// Add album cover URL if exists
	if coverArtPath.Valid && coverArtPath.String != "" {
		coverURL := fmt.Sprintf("%s/uploads/%s", baseURL, coverArtPath.String)
		response.AlbumCoverURL = &coverURL
	}

	w.Header().Set("Content-Type", "application/json")
	json.NewEncoder(w).Encode(response)
}

// serveAudioFileHandler serves audio files directly via /uploads/<path>
func serveAudioFileHandler(w http.ResponseWriter, r *http.Request) {
	enableCORS(w)

	// Extract the path after /uploads/
	urlPath := strings.TrimPrefix(r.URL.Path, "/uploads/")
	if urlPath == "" {
		http.Error(w, "File path is required", http.StatusBadRequest)
		return
	}

	// Check if this is an LRC request
	if strings.HasSuffix(urlPath, "/lrc") {
		// Handle LRC file request
		folderPath := strings.TrimSuffix(urlPath, "/lrc")

		// Find the LRC file in the database
		var lrcPath sql.NullString
		err := db.QueryRowContext(r.Context(),
			"SELECT lrc_path FROM music_files WHERE path LIKE ?",
			folderPath+"%",
		).Scan(&lrcPath)

		if err != nil || !lrcPath.Valid || lrcPath.String == "" {
			http.Error(w, "Lyric file not found", http.StatusNotFound)
			return
		}

		fullPath := filepath.Join(UPLOAD_FOLDER, lrcPath.String)

		// Read and parse the LRC file
		content, err := os.ReadFile(fullPath)
		if err != nil {
			log.Printf("Error reading lrc file '%s': %v", fullPath, err)
			http.Error(w, "Error reading lyric file", http.StatusInternalServerError)
			return
		}

		// Split into lines and trim whitespace
		lines := strings.Split(string(content), "\n")
		var cleanLines []string
		for _, line := range lines {
			cleanLines = append(cleanLines, strings.TrimSpace(line))
		}

		// Return as JSON array
		w.Header().Set("Content-Type", "application/json")
		json.NewEncoder(w).Encode(cleanLines)
		return
	}

	// Handle regular file serving (audio, images, etc.)
	fullPath := filepath.Join(UPLOAD_FOLDER, urlPath)

	// Check if the file exists
	fi, err := os.Stat(fullPath)
	if err != nil || fi.IsDir() {
		http.Error(w, "File not found", http.StatusNotFound)
		return
	}

	// Open the file
	f, err := os.Open(fullPath)
	if err != nil {
		http.Error(w, err.Error(), http.StatusInternalServerError)
		return
	}
	defer f.Close()

	// Create a section reader for proper range support
	rs := io.NewSectionReader(f, 0, fi.Size())

	// Set appropriate headers for audio streaming
	ext := strings.ToLower(filepath.Ext(urlPath))
	contentType := "application/octet-stream"
	switch ext {
	case ".mp3":
		contentType = "audio/mpeg"
	case ".flac":
		contentType = "audio/flac"
	case ".ogg":
		contentType = "audio/ogg"
	case ".wav":
		contentType = "audio/wav"
	case ".m4a", ".aac":
		contentType = "audio/aac"
	case ".png":
		contentType = "image/png"
	case ".jpg", ".jpeg":
		contentType = "image/jpeg"
	}

	filename := filepath.Base(urlPath)

	// Important: Prevent intermediary transformations (like gzip/transcoding) that could break byte alignment with frame boundaries
	w.Header().Set("Content-Type", contentType)
	w.Header().Set("Accept-Ranges", "bytes")
	w.Header().Set("Cache-Control", "public, no-transform")
	w.Header().Set("Connection", "keep-alive")
	w.Header().Set("Content-Disposition", "inline; filename="+filename)

	// Use ServeContent for proper range request support
	http.ServeContent(w, r, filename, fi.ModTime(), rs)
}

// lrcHandler serves the lyric file.
func lrcHandler(w http.ResponseWriter, r *http.Request) {
	enableCORS(w)
	lrcPath := r.URL.Query().Get("path")
	if lrcPath == "" {
		http.Error(w, "path parameter is required", http.StatusBadRequest)
		return
	}

	// Build the full file path
	fullPath := filepath.Join(UPLOAD_FOLDER, lrcPath)

	// Check if the file exists
	if _, err := os.Stat(fullPath); os.IsNotExist(err) {
		http.Error(w, "Lyric file not found", http.StatusNotFound)
		return
	}

	// Read and parse the LRC file
	content, err := os.ReadFile(fullPath)
	if err != nil {
		log.Printf("Error reading lrc file '%s': %v", fullPath, err)
		http.Error(w, "Error reading lyric file", http.StatusInternalServerError)
		return
	}

	// Split into lines and trim whitespace
	lines := strings.Split(string(content), "\n")
	var cleanLines []string
	for _, line := range lines {
		cleanLines = append(cleanLines, strings.TrimSpace(line))
	}

	// Return as JSON array
	w.Header().Set("Content-Type", "application/json")
	json.NewEncoder(w).Encode(cleanLines)
}

// downloadHandler serves files for download (can be music, lyrics, or covers).
func downloadHandler(w http.ResponseWriter, r *http.Request) {
	enableCORS(w)
	filePath := strings.TrimPrefix(r.URL.Path, "/files/")
	if filePath == "" {
		http.Error(w, "File path is required", http.StatusBadRequest)
		return
	}

	// Build the full file path
	fullPath := filepath.Join(UPLOAD_FOLDER, filePath)

	// Security: Ensure the file path is within the intended directory
	absUploadFolder, _ := filepath.Abs(UPLOAD_FOLDER)
	absFilePath, _ := filepath.Abs(fullPath)
	if !strings.HasPrefix(absFilePath, absUploadFolder) {
		http.Error(w, "Invalid file path", http.StatusBadRequest)
		return
	}

	// Check if file exists
	if _, err := os.Stat(fullPath); os.IsNotExist(err) {
		http.Error(w, "File not found", http.StatusNotFound)
		return
	}

	filename := filepath.Base(filePath)
	w.Header().Set("Content-Disposition", "attachment; filename="+filename)
	http.ServeFile(w, r, fullPath)
}

